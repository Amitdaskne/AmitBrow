<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg">
    <androidx.cardview.widget.CardView
        android:id="@+id/headerGlass"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/glass_margin"
        app:cardCornerRadius="@dimen/glass_corner_radius"
        app:cardElevation="@dimen/glass_elevation"
        app:cardBackgroundColor="@color/glass_bg"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/glass_padding">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AmitBrow"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/primary_gradient_start"
                android:layout_gravity="center" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Premium Browser"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_gravity="center"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <androidx.cardview.widget.CardView
        android:id="@+id/searchGlass"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/glass_margin"
        app:cardCornerRadius="@dimen/glass_corner_radius"
        app:cardElevation="@dimen/glass_elevation"
        app:cardBackgroundColor="@color/glass_bg"
        app:layout_constraintTop_toBottomOf="@id/headerGlass"
        android:layout_marginTop="16dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/glass_padding">
            <EditText
                android:id="@+id/searchInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Search or type URL..."
                android:background="@android:color/transparent"
                android:textSize="@dimen/url_text_size"
                android:imeOptions="actionGo"
                android:inputType="textUri"
                android:singleLine="true" />
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_search"
                android:layout_gravity="center"
                android:onClick="openBrowser" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <androidx.cardview.widget.CardView
        android:id="@+id/quickAccess"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="@dimen/glass_margin"
        app:cardCornerRadius="@dimen/glass_corner_radius"
        app:cardElevation="@dimen/glass_elevation"
        app:cardBackgroundColor="@color/glass_bg"
        app:layout_constraintTop_toBottomOf="@id/searchGlass"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">
        <GridView
            android:id="@+id/quickAccessGrid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:numColumns="2"
            android:verticalSpacing="8dp"
            android:horizontalSpacing="8dp"
            android:padding="@dimen/glass_padding" />
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>
