<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg">
    <androidx.cardview.widget.CardView
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/glass_margin"
        app:cardCornerRadius="@dimen/glass_corner_radius"
        app:cardElevation="@dimen/glass_elevation"
        app:cardBackgroundColor="@color/glass_bg"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/glass_padding">
            <HorizontalScrollView
                android:id="@+id/tabScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">
                <LinearLayout
                    android:id="@+id/tabContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">
                <ImageView
                    android:id="@+id/backBtn"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_media_previous"
                    android:padding="6dp"
                    android:onClick="goBack" />
                <ImageView
                    android:id="@+id/forwardBtn"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_media_next"
                    android:padding="6dp"
                    android:onClick="goForward" />
                <EditText
                    android:id="@+id/urlBar"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/glass_bg"
                    android:paddingHorizontal="12dp"
                    android:textSize="@dimen/url_text_size"
                    android:hint="Search or type URL"
                    android:imeOptions="actionGo"
                    android:inputType="textUri"
                    android:singleLine="true" />
                <ImageView
                    android:id="@+id/refreshBtn"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_rotate"
                    android:padding="6dp"
                    android:onClick="refresh" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="@dimen/glass_margin"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        android:layout_marginTop="4dp" />
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/glass_margin"
        app:cardCornerRadius="@dimen/glass_corner_radius"
        app:cardElevation="@dimen/glass_elevation"
        app:cardBackgroundColor="@color/glass_bg"
        app:layout_constraintBottom_toBottomOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/glass_padding"
            android:gravity="center">
            <ImageView
                android:layout_width="0dp"
                android:layout_height="@dimen/nav_button_size"
                android:layout_weight="1"
                android:src="@android:drawable/ic_menu_home"
                android:padding="8dp"
                android:onClick="goHome" />
            <ImageView
                android:layout_width="0dp"
                android:layout_height="@dimen/nav_button_size"
                android:layout_weight="1"
                android:src="@android:drawable/ic_menu_recent_history"
                android:padding="8dp"
                android:onClick="showBookmarks" />
            <ImageView
                android:layout_width="0dp"
                android:layout_height="@dimen/nav_button_size"
                android:layout_weight="1"
                android:src="@android:drawable/ic_menu_share"
                android:padding="8dp"
                android:onClick="sharePage" />
            <ImageView
                android:layout_width="0dp"
                android:layout_height="@dimen/nav_button_size"
                android:layout_weight="1"
                android:src="@android:drawable/ic_menu_add"
                android:padding="8dp"
                android:onClick="newTab" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>
